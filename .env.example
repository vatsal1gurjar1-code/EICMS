# ─────────────────────────────────────────────────────────────────────────────
# EICMS — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   copy .env.example .env
#   2. Fill in your real values in the .env file
#   3. NEVER commit the .env file to Git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# This connects the FastAPI backend directly to Supabase PostgreSQL.
# Use your Supabase connection string. Include sslmode=require for hosted
# Supabase Postgres or pooler endpoints.
#
# Examples:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.scwwzjnyiapskutqqotw:vatsalpranay123@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── JWT Authentication ────────────────────────────────────────────────────────
# A long random secret string used to sign login tokens.
# Generate one by running: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: Change this before going to production!
JWT_SECRET_KEY=change_this_to_a_long_random_secret_string_before_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# ── Super Admin Account ───────────────────────────────────────────────────────
# This account is created automatically when the backend starts if it does not exist.
# IMPORTANT: Change these before going to production!
SUPER_ADMIN_EMAIL=superadmin@eicms.local
SUPER_ADMIN_PASSWORD=change_this_password_before_production

# ── SendGrid (Email Alerts) ───────────────────────────────────────────────────
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# Leave blank during development — alerts will be logged to console instead.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# ── Application ───────────────────────────────────────────────────────────────
# The URL of the frontend (used for CORS configuration).
# For local development, this is always http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Environment: "development" or "production"
ENVIRONMENT=development

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL of the backend API (used by React to make API calls).
VITE_API_BASE_URL=http://localhost:8000
